print('Welcome TO Instant Discount App')
name = input('Enter Your Name ,Please').capitalize()
print(f'Welcome Mr/Miss :{name}')
price = float(input('Enter Your Price ,Please'))
if price < 100 :
    print(f"MR/Miss: {name} , Sorry you don't have any Discount.")
elif price >= 100 and price < 500 :
    discount = price * .1
    print(f"MR/Miss: {name} ,your Discounted Value : {discount:.2f}  \n  Your price after discount is :{price - discount}.")
else :
    discount = price * .2
    print(f"Mr/Miss {name}, your discount is: {discount}")
    print(f"Your price after discount is: {price - discount}")
